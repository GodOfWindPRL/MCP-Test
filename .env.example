# Đặt trong MCP config (env) cùng với TronLink MCP nếu muốn send_funds dùng ví “API”.

# Bắt buộc để coi là “đã có TronLink MCP” (agent / bạn tự đặt = true khi đã cài MCP TronLink).
TRONLINK_MCP_AVAILABLE=true

# Một trong hai: private key ví dùng khi TronLink MCP đã sẵn sàng (khớp tên env thường dùng với mcp-server-tronlink).
# TRONLINK_API_PRIVATE_KEY=
# TL_MINIMAL_TEST_PRIVATE_KEY=

# Node TRON (mặc định Nile testnet nếu không set).
# TL_TRONGRID_URL=https://nile.trongrid.io
